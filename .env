# Environment Variables

# Backend server port
BACKEND_PORT=3002

# MongoDB connection string (required for storing news)
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=

# Gemini API key (required for AI news summarization)
# Get this from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI key (optional, fallback for Gemini)
OPENAI_API_KEY=

# Redis URL (optional, used by BullMQ if needed)
REDIS_URL=

# Frontend
VITE_BACKEND_URL=http://localhost:3002